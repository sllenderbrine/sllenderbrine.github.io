{
  "compilerOptions": {
    "rootDir": "./projects",

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": ["DOM", "ES2022"],
    "strict": true,

    "noUncheckedIndexedAccess": true,

    "inlineSourceMap": true,
    "inlineSources": true,

    "skipLibCheck": true
  },
  "exclude": ["node_modules"],
}